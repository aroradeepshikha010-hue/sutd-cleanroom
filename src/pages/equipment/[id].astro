---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import { equipment, categories, categoryColors } from "../../data/equipment";
import type { GetStaticPaths } from "astro";

import "../../styles/global.css";

export const getStaticPaths = (() => {
  return equipment.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}) satisfies GetStaticPaths;

const { item } = Astro.props;
const color = categoryColors[item.category];
const categoryLabel = categories.find((c) => c.id === item.category)?.label ?? item.category;
---

<Layout title={`${item.name} — SUTD Cleanroom`} description={item.description}>
  <Navigation />

  <main class="pt-24 pb-16 px-6">
    <div class="max-w-5xl mx-auto">

      <!-- Back link -->
      <a href="/#equipment" class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Equipment
      </a>

      <!-- Two-column layout -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- Left: Image + Description + Features (2/3 width) -->
        <div class="lg:col-span-2">
          <!-- Equipment image -->
          <div class="rounded-2xl overflow-hidden border border-border mb-8 bg-surface-elevated p-6 flex items-center justify-center min-h-[300px]">
            {item.imageSrc ? (
              <img
                src={item.imageSrc}
                alt={item.name}
                class="max-w-full max-h-[500px] object-contain rounded-lg"
                loading="eager"
              />
            ) : (
              <div class="w-full aspect-[16/10] flex items-center justify-center">
                <svg class="w-16 h-16 text-text-muted opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
            )}
          </div>

          <!-- Description -->
          <h2 class="text-sm font-semibold text-text-muted uppercase tracking-widest mb-3">Description</h2>
          <p class="text-text-secondary leading-relaxed text-lg mb-10">
            {item.description}
          </p>

          <!-- Features -->
          <h2 class="text-sm font-semibold text-text-muted uppercase tracking-widest mb-4">Capabilities & Features</h2>
          <ul class="space-y-3">
            {item.features.map((f) => (
              <li class="flex items-start gap-3 text-text-secondary">
                <svg class="w-5 h-5 shrink-0 mt-0.5" style={`color: ${color};`} fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: Specs sidebar (1/3 width) -->
        <div>
          <div class="bg-surface-card border border-border rounded-2xl p-6 sticky top-24">
            <!-- Category badge -->
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold mb-6" style={`background-color: ${color}20; color: ${color};`}>
              <span class="w-2 h-2 rounded-full" style={`background-color: ${color};`}></span>
              {categoryLabel}
            </div>

            <!-- Name & Model -->
            <h1 class="text-2xl font-bold text-white mb-1 leading-tight">{item.name}</h1>
            <p class="text-base text-accent font-medium mb-6">{item.model}</p>

            <!-- Key spec -->
            <div class="border-t border-border pt-5 mb-5">
              <p class="text-xs text-text-muted uppercase tracking-widest mb-1">Key Specification</p>
              <p class="text-white font-semibold">{item.keySpec}</p>
            </div>

            <!-- Since -->
            {item.since && (
              <div class="border-t border-border pt-5 mb-5">
                <p class="text-xs text-text-muted uppercase tracking-widest mb-1">In Operation Since</p>
                <p class="text-white font-semibold">{item.since}</p>
              </div>
            )}

            <!-- Features count -->
            <div class="border-t border-border pt-5">
              <p class="text-xs text-text-muted uppercase tracking-widest mb-1">Capabilities Listed</p>
              <p class="text-white font-semibold">{item.features.length}</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

  <Footer />

  <script src="../../scripts/navigation.ts"></script>
</Layout>
