---
import SectionHeading from "./ui/SectionHeading.astro";
---

<section id="contact" class="py-24 px-6 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-surface via-surface-elevated/30 to-surface pointer-events-none"></div>

  <div class="max-w-4xl mx-auto relative">
    <SectionHeading
      title="Get In Touch"
      subtitle="Interested in using our facilities, collaboration, or learning more about our capabilities?"
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-reveal-stagger>
      <!-- Address -->
      <div class="bg-surface-card border border-border rounded-xl p-6 text-center hover:border-border-hover transition-colors duration-300">
        <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-text-primary mb-2">Location</h3>
        <p class="text-sm text-text-secondary">
          Singapore University of<br />
          Technology and Design<br />
          8 Somapah Road, Singapore 487372
        </p>
      </div>

      <!-- Email -->
      <div class="bg-surface-card border border-border rounded-xl p-6 text-center hover:border-border-hover transition-colors duration-300">
        <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-text-primary mb-2">Email</h3>
        <p class="text-sm text-text-secondary">
          Contact details to be provided
        </p>
      </div>

      <!-- Hours -->
      <div class="bg-surface-card border border-border rounded-xl p-6 text-center hover:border-border-hover transition-colors duration-300">
        <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-text-primary mb-2">Operating Hours</h3>
        <p class="text-sm text-text-secondary">
          By appointment<br />
          Safety induction required<br />
          Full gowning protocol
        </p>
      </div>
    </div>
  </div>
</section>
