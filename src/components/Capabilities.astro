---
import SectionHeading from "./ui/SectionHeading.astro";
import { categories } from "../data/equipment";

const icons: Record<string, string> = {
  crosshair: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M12 2v4m0 12v4M2 12h4m12 0h4"/><circle cx="12" cy="12" r="3" stroke-width="1.5"/></svg>`,
  layers: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L12 12.75 6.43 9.75m11.14 0l4.179 2.25L12 17.25 2.25 12l4.179-2.25m11.142 0l4.179 2.25L12 22.5l-9.75-5.25 4.179-2.25" /></svg>`,
  zap: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
  search: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg>`,
  cpu: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5M4.5 15.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z" /></svg>`,
};

const descriptions: Record<string, string> = {
  lithography: "Patterning at the nanoscale with electron beam, laser, and imprint technologies.",
  deposition: "Growing and depositing thin films with atomic-level precision.",
  etching: "Selectively removing materials with plasma and chemical processes.",
  metrology: "Characterising structures, films, and devices at the nanoscale.",
  packaging: "Connecting devices, thermal processing, and cryogenic testing.",
};
---

<section id="capabilities" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <SectionHeading
      title="Capabilities"
      subtitle="20+ advanced tools across five core capability areas, from nanopatterning to device characterisation."
    />

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4" data-reveal-stagger>
      {categories.map((cat) => (
        <a
          href="#equipment"
          class="bg-surface-card border border-border rounded-xl p-6 text-center hover:border-accent/30 hover:bg-accent/5 transition-all duration-300 group block"
        >
          <div class="text-text-muted group-hover:text-accent transition-colors duration-300 flex justify-center mb-4" set:html={icons[cat.icon]} />
          <h3 class="text-sm font-semibold text-text-primary mb-1">{cat.label}</h3>
          <p class="text-xs text-text-muted mb-3">{descriptions[cat.id]}</p>
          <span class="inline-flex items-center gap-1 text-xs text-accent font-medium">
            {cat.count} tools
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
