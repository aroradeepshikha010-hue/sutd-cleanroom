---
---

<section id="timeline" class="py-24 px-6 relative">
  <div class="max-w-6xl mx-auto">

    <!-- Section heading -->
    <div class="text-center mb-20" data-reveal>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-4 tracking-tight">Our Vision & Mission</h2>
      <p class="text-lg text-text-secondary max-w-2xl mx-auto leading-relaxed">
        Building Singapore's future in quantum, semiconductor, and space through
        design-AI-centric training & research excellence.
      </p>
    </div>

    <!-- Timeline content wrapper (ball + line start here, after heading) -->
    <div class="relative" id="timeline-content">

    <!-- Center timeline line -->
    <div class="absolute left-1/2 top-0 bottom-0 w-px bg-border -translate-x-1/2 hidden lg:block"></div>
    <div class="absolute left-1/2 top-0 w-px -translate-x-1/2 hidden lg:block bg-accent transition-all duration-100" id="timeline-progress" style="height: 0;"></div>
    <div class="absolute left-1/2 -translate-x-1/2 hidden lg:block z-10" id="timeline-ball" style="top: 0;">
      <div class="w-4 h-4 rounded-full bg-accent shadow-[0_0_12px_rgba(180,83,9,0.5)] border-2 border-accent"></div>
    </div>

    <!-- Mobile line -->
    <div class="absolute left-6 top-0 bottom-0 w-px bg-border lg:hidden"></div>
    <div class="absolute left-6 top-0 w-px bg-accent lg:hidden transition-all duration-100" id="timeline-progress-mobile" style="height: 0;"></div>
    <div class="absolute left-6 -translate-x-1/2 lg:hidden z-10" id="timeline-ball-mobile" style="top: 0;">
      <div class="w-3 h-3 rounded-full bg-accent shadow-[0_0_10px_rgba(180,83,9,0.5)]"></div>
    </div>

    <!-- ═══════ 1. RESEARCH EXCELLENCE ═══════ -->
    <div class="timeline-item relative mb-24" data-reveal>
      <!-- Desktop -->
      <div class="hidden lg:grid grid-cols-2 gap-16 items-center">
        <!-- Images left: two journal covers side by side -->
        <div class="flex gap-4">
          <div class="flex-1 rounded-2xl overflow-hidden border border-border">
            <img src="/sutd-cleanroom/images/research/Research & Innovation.png" alt="Nature Nanotechnology cover" class="w-full aspect-[3/4] object-cover" loading="lazy" />
          </div>
          <div class="flex-1 rounded-2xl overflow-hidden border border-border">
            <img src="/sutd-cleanroom/images/research/Research & Innovationv2.png" alt="Advanced Optical Materials cover" class="w-full aspect-[3/4] object-cover" loading="lazy" />
          </div>
        </div>
        <!-- Text right -->
        <div class="pl-8">
          <h3 class="text-3xl font-bold text-text-primary mb-4 leading-tight">Research & Innovation</h3>
          <p class="text-text-secondary leading-relaxed">
            World-class nanotech research at low-to-mid TRL, driving innovation in quantum technologies, semiconductors, and space. Our cleanroom has enabled publications in Nature Nanotechnology, Science Advances, ACS Nano, and more.
          </p>
        </div>
      </div>
      <!-- Mobile -->
      <div class="lg:hidden pl-12">
        <h3 class="text-2xl font-bold text-text-primary mb-3">Research & Innovation</h3>
        <div class="flex gap-3 mb-4">
          <div class="flex-1 rounded-xl overflow-hidden border border-border">
            <img src="/sutd-cleanroom/images/research/Research & Innovation.png" alt="Nature Nanotechnology cover" class="w-full aspect-[3/4] object-cover" loading="lazy" />
          </div>
          <div class="flex-1 rounded-xl overflow-hidden border border-border">
            <img src="/sutd-cleanroom/images/research/Research & Innovationv2.png" alt="Advanced Optical Materials cover" class="w-full aspect-[3/4] object-cover" loading="lazy" />
          </div>
        </div>
        <p class="text-text-secondary leading-relaxed text-sm">World-class nanotech research driving innovation in quantum technologies, semiconductors, and space.</p>
      </div>
      <!-- Center dot -->
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 hidden lg:block"><div class="w-3 h-3 rounded-full bg-surface-card border-2 border-border"></div></div>
      <div class="absolute left-6 top-8 -translate-x-1/2 lg:hidden"><div class="w-2.5 h-2.5 rounded-full bg-surface-card border-2 border-border"></div></div>
    </div>

    <!-- ═══════ 2. HANDS-ON EDUCATION ═══════ -->
    <div class="timeline-item relative mb-24" data-reveal>
      <!-- Desktop: text left, image right -->
      <div class="hidden lg:grid grid-cols-2 gap-16 items-center">
        <div class="pr-8 text-right">
          <h3 class="text-3xl font-bold text-text-primary mb-4 leading-tight">Hands-On Education</h3>
          <p class="text-text-secondary leading-relaxed">
            UG and PG students gain first-principles cleanroom experience — from design to device. Our philosophy: learn by doing. Students undertake complete fabrication projects using publication-grade equipment.
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden border border-border">
          <img src="/sutd-cleanroom/images/Education /Education.png" alt="Students in the SUTD Cleanroom" class="w-full object-contain" loading="lazy" />
        </div>
      </div>
      <!-- Mobile -->
      <div class="lg:hidden pl-12">
        <h3 class="text-2xl font-bold text-text-primary mb-3">Hands-On Education</h3>
        <div class="rounded-xl overflow-hidden border border-border mb-4">
          <img src="/sutd-cleanroom/images/Education /Education.png" alt="Students in the SUTD Cleanroom" class="w-full object-contain" loading="lazy" />
        </div>
        <p class="text-text-secondary leading-relaxed text-sm">UG and PG students gain first-principles cleanroom experience — from design to device.</p>
      </div>
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 hidden lg:block"><div class="w-3 h-3 rounded-full bg-surface-card border-2 border-border"></div></div>
      <div class="absolute left-6 top-8 -translate-x-1/2 lg:hidden"><div class="w-2.5 h-2.5 rounded-full bg-surface-card border-2 border-border"></div></div>
    </div>

    <!-- ═══════ 3. DEEP-TECH STARTUPS ═══════ -->
    <div class="timeline-item relative" data-reveal>
      <!-- Desktop: logos left, text right -->
      <div class="hidden lg:grid grid-cols-2 gap-16 items-center">
        <!-- Startup logos grid -->
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-surface-card border border-border rounded-2xl p-6 flex items-center justify-center aspect-[4/3]">
            <img src="/sutd-cleanroom/images/Startups/startup1.png" alt="CellWave Technologies" class="max-h-16 object-contain" loading="lazy" />
          </div>
          <div class="bg-surface-card border border-border rounded-2xl p-6 flex items-center justify-center aspect-[4/3]">
            <img src="/sutd-cleanroom/images/Startups/startup2.jpg" alt="Enlitho" class="max-h-16 object-contain" loading="lazy" />
          </div>
          <div class="bg-surface-card border border-border rounded-2xl p-6 flex items-center justify-center aspect-[4/3]">
            <img src="/sutd-cleanroom/images/Startups/startup3.png" alt="Metatag" class="max-h-12 object-contain" loading="lazy" />
          </div>
          <div class="bg-surface-card border border-border rounded-2xl p-6 flex items-center justify-center aspect-[4/3]">
            <img src="/sutd-cleanroom/images/Startups/startup4.jpg" alt="Polymate" class="max-h-16 object-contain" loading="lazy" />
          </div>
        </div>
        <!-- Text right -->
        <div class="pl-8">
          <h3 class="text-3xl font-bold text-text-primary mb-4 leading-tight">Deep-Tech Startups</h3>
          <p class="text-text-secondary leading-relaxed">
            The SUTD Cleanroom has incubated multiple deep-tech ventures — turning cutting-edge research into commercial products. From precision lithography to advanced materials, our startups are shaping Singapore's innovation landscape.
          </p>
        </div>
      </div>
      <!-- Mobile -->
      <div class="lg:hidden pl-12">
        <h3 class="text-2xl font-bold text-text-primary mb-3">Deep-Tech Startups</h3>
        <div class="grid grid-cols-2 gap-3 mb-4">
          <div class="bg-surface-card border border-border rounded-xl p-4 flex items-center justify-center aspect-[4/3]">
            <img src="/sutd-cleanroom/images/Startups/startup1.png" alt="CellWave Technologies" class="max-h-12 object-contain" loading="lazy" />
          </div>
          <div class="bg-surface-card border border-border rounded-xl p-4 flex items-center justify-center aspect-[4/3]">
            <img src="/sutd-cleanroom/images/Startups/startup2.jpg" alt="Enlitho" class="max-h-12 object-contain" loading="lazy" />
          </div>
          <div class="bg-surface-card border border-border rounded-xl p-4 flex items-center justify-center aspect-[4/3]">
            <img src="/sutd-cleanroom/images/Startups/startup3.png" alt="Metatag" class="max-h-10 object-contain" loading="lazy" />
          </div>
          <div class="bg-surface-card border border-border rounded-xl p-4 flex items-center justify-center aspect-[4/3]">
            <img src="/sutd-cleanroom/images/Startups/startup4.jpg" alt="Polymate" class="max-h-12 object-contain" loading="lazy" />
          </div>
        </div>
        <p class="text-text-secondary leading-relaxed text-sm">Incubating deep-tech ventures — turning cutting-edge research into commercial products.</p>
      </div>
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 hidden lg:block"><div class="w-3 h-3 rounded-full bg-surface-card border-2 border-border"></div></div>
      <div class="absolute left-6 top-8 -translate-x-1/2 lg:hidden"><div class="w-2.5 h-2.5 rounded-full bg-surface-card border-2 border-border"></div></div>
    </div>

    </div><!-- end timeline-content -->

  </div>
</section>

<script>
  const timelineContent = document.getElementById('timeline-content');
  const ball = document.getElementById('timeline-ball');
  const progress = document.getElementById('timeline-progress');
  const ballMobile = document.getElementById('timeline-ball-mobile');
  const progressMobile = document.getElementById('timeline-progress-mobile');

  if (timelineContent && ball && progress) {
    let ticking = false;
    function updateTimeline() {
      const rect = timelineContent.getBoundingClientRect();
      const sectionHeight = rect.height;
      const viewportHeight = window.innerHeight;
      const scrolled = -rect.top + viewportHeight * 0.4;
      const ratio = Math.max(0, Math.min(1, scrolled / sectionHeight));
      const pos = ratio * (sectionHeight - 48);

      ball.style.top = pos + 'px';
      progress.style.height = pos + 'px';
      if (ballMobile && progressMobile) {
        ballMobile.style.top = pos + 'px';
        progressMobile.style.height = pos + 'px';
      }
      ticking = false;
    }
    window.addEventListener('scroll', () => { if (!ticking) { requestAnimationFrame(updateTimeline); ticking = true; } });
    updateTimeline();
  }
</script>
