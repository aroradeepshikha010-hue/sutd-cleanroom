---
interface Props {
  value: string;
  label: string;
  prefix?: string;
  suffix?: string;
  isNumeric?: boolean;
}

const { value, label, prefix = "", suffix = "", isNumeric = true } = Astro.props;
---

<div class="text-center p-6">
  <div class="text-4xl md:text-5xl font-bold text-white mb-2">
    {prefix}<span data-counter={isNumeric ? value : undefined}>{value}</span>{suffix}
  </div>
  <div class="text-sm text-text-muted uppercase tracking-widest">{label}</div>
</div>
