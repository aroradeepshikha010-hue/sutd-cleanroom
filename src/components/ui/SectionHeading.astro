---
interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}

const { title, subtitle, align = "center" } = Astro.props;
const alignClass = align === "center" ? "text-center" : "text-left";
---

<div class={`mb-16 ${alignClass}`} data-reveal>
  <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-4 tracking-tight">
    {title}
  </h2>
  {subtitle && (
    <p class="text-lg text-text-secondary max-w-2xl mx-auto leading-relaxed">
      {subtitle}
    </p>
  )}
</div>
