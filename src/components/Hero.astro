---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background image with gradient overlay -->
  <div class="absolute inset-0">
    <img
      src="/sutd-cleanroom/images/hero/cleanroom-overview.jpg"
      alt="SUTD Cleanroom facility"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/50 to-surface"></div>
  </div>

  <!-- Content (text stays white over hero image) -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <!-- Overline badge -->
    <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-black/20 backdrop-blur-sm text-sm text-white mb-8 animate-fade-in">
      <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
      Class 1000 (ISO 6) Certified Facility
    </div>

    <!-- Title -->
    <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 tracking-tight leading-[1.05] animate-slide-up">
      SUTD<br />
      <span class="text-white/70">Cleanroom</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-16 leading-relaxed animate-slide-up" style="animation-delay: 0.15s;">
      Pioneering micro & nanofabrication — enabling cutting-edge research,
      world-class education, and deep-tech entrepreneurship in Singapore.
    </p>

    <!-- Scroll indicator -->
    <a href="#about" class="inline-block animate-bounce-subtle" aria-label="Scroll down">
      <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </div>
</section>
