---
import SectionHeading from "./ui/SectionHeading.astro";

const services = [
  "Optical design",
  "Precision lithography",
  "Mould fabrication",
  "Rapid prototyping",
  "Technology translation",
  "Nanoimprint lithography",
];
---

<section id="startups" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <SectionHeading
      title="Deep-Tech Entrepreneurship"
      subtitle="Enabling next-generation startups from cutting-edge research — from lab bench to market."
    />

    <!-- Enlitho case study -->
    <div class="bg-surface-card border border-border rounded-2xl p-8 md:p-12 hover:border-border-hover transition-colors duration-300" data-reveal>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <!-- Left: story -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-white">Enlitho Pte Ltd</h3>
              <p class="text-sm text-text-muted">Founded 2017 | Born in the SUTD Cleanroom</p>
            </div>
          </div>

          <p class="text-text-secondary leading-relaxed mb-4">
            Enlitho is a Singapore-based micro-nanofabrication company that was
            born directly from research conducted in the SUTD Cleanroom. What
            began as academic innovation has grown into a commercial enterprise
            serving the region's advanced manufacturing needs.
          </p>
          <p class="text-text-secondary leading-relaxed mb-6">
            This is the model we champion: turning cutting-edge cleanroom research
            into viable deep-tech ventures. The SUTD Cleanroom provides not just
            the equipment, but the expertise and environment to nurture these
            transitions.
          </p>

          <div class="inline-flex items-center gap-2 text-sm text-accent">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
            From Research Lab to Market
          </div>
        </div>

        <!-- Right: services -->
        <div>
          <h4 class="text-sm font-semibold text-text-muted uppercase tracking-widest mb-6">Capabilities & Services</h4>
          <div class="grid grid-cols-2 gap-3">
            {services.map((s) => (
              <div class="flex items-center gap-3 p-3 rounded-lg bg-surface-elevated border border-border">
                <svg class="w-4 h-4 text-accent shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm text-text-secondary">{s}</span>
              </div>
            ))}
          </div>

          <!-- CTA note -->
          <div class="mt-8 p-4 rounded-xl bg-accent/5 border border-accent/20">
            <p class="text-sm text-text-secondary">
              <span class="text-white font-medium">Have a deep-tech idea?</span> The SUTD Cleanroom
              welcomes researchers and entrepreneurs looking to translate innovation
              into products.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
