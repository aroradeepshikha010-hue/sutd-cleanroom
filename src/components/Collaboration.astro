---
import SectionHeading from "./ui/SectionHeading.astro";

const opportunities = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342" /></svg>`,
    title: "STEM Workshops",
    description: "Hands-on STEM workshops for schools and institutions, introducing students to the world of nanotechnology and cleanroom fabrication.",
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" /></svg>`,
    title: "Industrial Access",
    description: "Equipment access for industry R&D and prototyping. Partner with us to leverage world-class nanofabrication capabilities.",
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
    title: "Equipment Testing",
    description: "Testing and evaluation services for your materials and devices using our comprehensive metrology and characterisation suite.",
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.42 15.17l-5.1-5.1m0 0L12 4.37m-5.68 5.7h11.8M4.64 18.38a9 9 0 1114.72 0" /></svg>`,
    title: "Hands-on Training",
    description: "Cleanroom safety induction and hands-on process training courses for researchers, students, and industry professionals.",
  },
];
---

<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <SectionHeading
      title="Collaborate With Us"
      subtitle="Partnership opportunities for academia, industry, and aspiring entrepreneurs."
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6" data-reveal-stagger>
      {opportunities.map((opp) => (
        <div class="bg-surface-card border border-border rounded-xl p-6 hover:border-accent/30 hover:bg-accent/5 transition-all duration-300 group text-center">
          <div class="text-text-muted group-hover:text-accent transition-colors duration-300 flex justify-center mb-4" set:html={opp.icon} />
          <h3 class="text-base font-semibold text-text-primary mb-2">{opp.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{opp.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
