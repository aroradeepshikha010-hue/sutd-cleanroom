---
import { navLinks } from "../data/navigation";
---

<footer class="border-t border-border bg-surface py-12 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
      <!-- Branding -->
      <div>
        <div class="mb-4">
          <img src="/sutd-cleanroom/images/logos/sutd_v2.png" alt="SUTD" class="h-10 w-10 mb-2" />
          <span class="text-text-muted text-xs block">Class 1000 (ISO 6) Cleanroom</span>
        </div>
        <p class="text-sm text-text-muted leading-relaxed">
          State-of-the-art micro/nanofabrication facility enabling research
          excellence, education, and deep-tech entrepreneurship.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="text-sm font-semibold text-text-primary mb-4">Quick Links</h4>
        <div class="grid grid-cols-2 gap-2">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-text-muted hover:text-text-primary transition-colors duration-200"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <!-- SUTD info -->
      <div>
        <h4 class="text-sm font-semibold text-text-primary mb-4">SUTD</h4>
        <p class="text-sm text-text-muted leading-relaxed mb-4">
          Singapore University of Technology and Design<br />
          8 Somapah Road<br />
          Singapore 487372
        </p>
        <!-- Social icons -->
        <div class="flex gap-4">
          <a href="#" class="text-text-muted hover:text-text-primary transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="#" class="text-text-muted hover:text-text-primary transition-colors" aria-label="Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" class="text-text-muted hover:text-text-primary transition-colors" aria-label="Email">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-border text-center">
      <p class="text-xs text-text-muted">
        &copy; {new Date().getFullYear()} SUTD Cleanroom. Singapore University of Technology and Design. All rights reserved.
      </p>
    </div>
  </div>
</footer>
